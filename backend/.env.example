# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5433/nexus

# Porta da API
PORT=3001

# Usuário admin inicial do dashboard (criado na 1ª migração, se não houver usuários)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# IA (opcional) — se ausente, draftMessage usa fallback por template
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Qualificação de leads (opcional) — se ausente, leadQualifier degrada para checagem básica
SERPAPI_KEY=

# WhatsApp Cloud API (opcional) — também cadastrável pela UI em Configurações
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=
# App Secret do app da Meta — valida a assinatura (HMAC) dos webhooks recebidos.
WHATSAPP_APP_SECRET=
