# Produção — copie para .env e ajuste antes de subir:
#   cp .env.prod.example .env
#   docker compose -f docker-compose.prod.yml up -d --build

# Postgres (USE UMA SENHA FORTE)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=nexus

# Porta pública do app (UI + API juntas) — usada por docker-compose.prod.yml
APP_PORT=3001

# Usuário admin inicial do dashboard (USE UMA SENHA FORTE)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-esta-senha

# HTTPS automático (Caddy) — usado por docker-compose.caddy.yml
# Aponte o DNS do domínio para o IP da VPS antes de subir.
DOMAIN=
TLS_EMAIL=

# Chaves opcionais — pode deixar vazio e cadastrar pela UI em Configurações
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
SERPAPI_KEY=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=
